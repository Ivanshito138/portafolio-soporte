---
import BaseLayout from '../layouts/BaseLayout.astro';
import { translations } from '../data/translations.ts';

const t = translations.es;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={t.notFound.title} lang="es">
  <section class="min-h-screen flex items-center justify-center bg-white dark:bg-gray-900 pt-20">
    <div class="text-center px-4">
      <p class="text-8xl font-bold text-blue-600 dark:text-blue-400 mb-4">404</p>
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4 font-heading">{t.notFound.title}</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 mb-8">{t.notFound.description}</p>
      <a href={`${base}/`} class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors">
        {t.notFound.goHome}
      </a>
    </div>
  </section>
</BaseLayout>
