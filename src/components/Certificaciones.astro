---
interface Props {
  certifications: Array<{ name: string; issuer: string; year: number; icon: string; pdf?: string }>;
  t: typeof import('../data/translations.ts').translations.es;
}

const { certifications, t } = Astro.props;
---

<section id="certificaciones" class="py-20 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12 text-gray-900 dark:text-white font-heading">{t.certifications.title}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {certifications.map((cert) => (
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 text-center hover:shadow-lg dark:shadow-gray-700/30 transition-shadow border border-gray-100 dark:border-gray-700">
          <div class="text-4xl mb-4" aria-hidden="true">{cert.icon}</div>
          <h3 class="font-semibold text-gray-800 dark:text-gray-200 mb-2 font-heading">{cert.name}</h3>
          <p class="text-gray-500 dark:text-gray-400 text-sm">{cert.issuer}</p>
          <p class="text-blue-600 dark:text-blue-400 text-sm font-medium mt-2">{cert.year}</p>
          {cert.pdf && (
            <a
              href={cert.pdf}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1 text-xs bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 px-3 py-1.5 rounded-full hover:bg-blue-200 dark:hover:bg-blue-800 transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
              </svg>
              PDF
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
