---
interface Props {
  certifications: Array<{ name: string; issuer: string; year: number; icon: string; pdf?: string }>;
  t: typeof import('../data/translations.ts').translations.es;
}

const { certifications, t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="certificaciones" class="py-32 relative">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-20 reveal">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 font-heading">{t.certifications.title}</h2>
      <div class="w-24 h-1.5 bg-gradient-to-r from-brand-indigo to-brand-pink mx-auto rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {certifications.map((cert, index) => (
        <div 
          class="relative group reveal"
          style={`transition-delay: ${index * 50}ms`}
        >
          <!-- Digital Ticket Shape using Clip Path or Pseudo elements -->
          <div class="absolute inset-0 bg-gradient-to-br from-brand-indigo/20 to-brand-pink/20 rounded-3xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative glass rounded-3xl p-8 flex flex-col justify-between h-full border-dashed border-white/10 group-hover:border-white/30 transition-colors overflow-hidden">
            
            <!-- Ticket Cutouts (Visual Only) -->
            <div class="absolute -left-3 top-1/2 -translate-y-1/2 w-6 h-6 bg-void rounded-full border-r border-white/10"></div>
            <div class="absolute -right-3 top-1/2 -translate-y-1/2 w-6 h-6 bg-void rounded-full border-l border-white/10"></div>

            <div class="flex items-start justify-between mb-8">
              <div class="w-14 h-14 glass rounded-2xl flex items-center justify-center text-3xl">
                {cert.icon}
              </div>
              <div class="text-right">
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-1">{t.certifications.year}</p>
                <p class="text-xl font-bold font-mono text-brand-pink">{cert.year}</p>
              </div>
            </div>

            <div>
              <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">{t.certifications.credential}</p>
              <h3 class="text-xl font-bold mb-2 font-heading group-hover:text-white transition-colors">
                {cert.name}
              </h3>
              <p class="text-sm text-gray-400">{cert.issuer}</p>
            </div>

            <div class="mt-10 flex items-center justify-between pt-6 border-t border-dashed border-white/10">
              <div class="flex gap-1">
                {[1, 2, 3, 4, 5].map(() => (
                  <div class="w-1.5 h-1.5 bg-white/10 rounded-full"></div>
                ))}
              </div>
              
              {cert.pdf && (
                <a
                  href={`${base}${cert.pdf}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="glass px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-widest hover:bg-white hover:text-void transition-all"
                >
                  {t.certifications.verify} <i class="ti ti-external-link ml-1"></i>
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
