---
import { Image } from 'astro:assets';
import fotoPerfil from '../assets/foto-perfil.webp';
import type { Lang } from '../data/translations.ts';

interface Props {
  name: string;
  title: string;
  tagline: string;
  t: typeof import('../data/translations.ts').translations.es;
}

const { name, title, tagline, t } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-600 to-blue-800 dark:from-blue-900 dark:to-blue-950 text-white pt-20">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <Image
      src={fotoPerfil}
      alt={`Photo of ${name}`}
      widths={[160, 320]}
      format="webp"
      loading="eager"
      fetchpriority="high"
      class="w-40 h-40 rounded-full mx-auto mb-8 border-4 border-white/30 object-cover shadow-xl"
    />
    <p class="text-blue-200 dark:text-blue-300 text-lg mb-2">{title}</p>
    <h1 class="text-4xl md:text-6xl font-bold mb-6 font-heading">{name}</h1>
    <p class="text-xl md:text-2xl text-blue-100 dark:text-blue-200 mb-8 max-w-2xl mx-auto">{tagline}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#proyectos" class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 dark:bg-gray-100 dark:hover:bg-gray-200 transition-colors">
        {t.hero.viewProjects}
      </a>
      <a href={`${base}/cv.pdf`} download class="bg-green-500 text-white px-6 py-3 rounded-lg font-semibold hover:bg-green-600 transition-colors">
        {t.hero.downloadCV}
      </a>
      <a href="#contacto" class="border-2 border-white text-white px-6 py-3 rounded-lg font-semibold hover:bg-white/10 transition-colors">
        {t.hero.contactMe}
      </a>
    </div>
  </div>
</section>
