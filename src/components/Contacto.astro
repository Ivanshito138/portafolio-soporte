---
interface Props {
  email: string;
  phone: string;
  location: string;
  linkedin: string;
  github: string;
  t: typeof import('../data/translations.ts').translations.es;
}

const { email, phone, location, linkedin, github, t } = Astro.props;
---

<section id="contacto" class="py-32 relative">
  <div class="max-w-4xl mx-auto px-4">
    <div class="glass rounded-[2.5rem] overflow-hidden reveal">
      
      <!-- Terminal Header -->
      <div class="bg-white/10 dark:bg-white/5 border-b border-white/10 px-6 py-4 flex items-center justify-between">
        <div class="flex gap-2">
          <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
        </div>
        <div class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">contact.exe — {location}</div>
        <div class="w-12"></div>
      </div>

      <div class="p-6 md:p-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          
          <!-- Contact Info -->
          <div class="min-w-0">
            <h2 class="text-3xl md:text-4xl font-bold mb-8 font-heading">{t.contact.title}</h2>
            <div class="space-y-8">
              <div class="group reveal">
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Email</p>
                <a href={`mailto:${email}`} class="text-base md:text-lg lg:text-xl font-bold text-white hover:text-brand-cyan transition-colors flex items-center gap-3 break-all">
                  <i class="ti ti-mail text-brand-cyan shrink-0"></i>
                  {email}
                </a>
              </div>

              <div class="group reveal [transition-delay:100ms]">
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Phone</p>
                <a href={`tel:${phone}`} class="text-xl md:text-2xl font-bold text-white hover:text-brand-indigo transition-colors flex items-center gap-3">
                  <i class="ti ti-phone text-brand-indigo shrink-0"></i>
                  {phone}
                </a>
              </div>

              <div class="flex gap-4 pt-4 reveal [transition-delay:200ms]">
                <a href={linkedin} target="_blank" class="w-14 h-14 glass rounded-2xl flex items-center justify-center text-2xl hover:bg-brand-cyan hover:text-void transition-all duration-300">
                  <i class="ti ti-brand-linkedin"></i>
                </a>
                <a href={github} target="_blank" class="w-14 h-14 glass rounded-2xl flex items-center justify-center text-2xl hover:bg-white hover:text-void transition-all duration-300">
                  <i class="ti ti-brand-github"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- Quick Message / Form Placeholder -->
          <div class="glass p-6 md:p-8 rounded-3xl border-brand-cyan/20 w-full lg:max-w-md ml-auto">
            <h4 class="text-lg font-bold mb-6 font-heading flex items-center gap-2">
              <span class="w-2 h-2 bg-brand-cyan rounded-full animate-pulse"></span>
              {t.contact.ticketTitle}
            </h4>
            
            <form class="space-y-6">
              <div class="relative">
                <input type="text" placeholder=" " class="peer w-full bg-transparent border-b border-white/10 py-3 focus:outline-none focus:border-brand-cyan transition-colors text-white" />
                <label class="absolute left-0 top-3 text-gray-500 transition-all peer-focus:-top-4 peer-focus:text-[10px] peer-focus:text-brand-cyan peer-focus:font-bold uppercase tracking-widest">{t.contact.nameLabel}</label>
              </div>
              <div class="relative">
                <input type="email" placeholder=" " class="peer w-full bg-transparent border-b border-white/10 py-3 focus:outline-none focus:border-brand-cyan transition-colors text-white" />
                <label class="absolute left-0 top-3 text-gray-500 transition-all peer-focus:-top-4 peer-focus:text-[10px] peer-focus:text-brand-cyan peer-focus:font-bold uppercase tracking-widest">{t.contact.emailLabel}</label>
              </div>
              <div class="relative">
                <textarea placeholder=" " rows="3" class="peer w-full bg-transparent border-b border-white/10 py-3 focus:outline-none focus:border-brand-cyan transition-colors text-white resize-none"></textarea>
                <label class="absolute left-0 top-3 text-gray-500 transition-all peer-focus:-top-4 peer-focus:text-[10px] peer-focus:text-brand-cyan peer-focus:font-bold uppercase tracking-widest">{t.contact.messageLabel}</label>
              </div>
              
              <button type="submit" class="w-full bg-brand-cyan text-void font-bold py-4 rounded-xl hover:glow-cyan transition-all uppercase tracking-widest text-xs">
                {t.contact.submitBtn}
              </button>
            </form>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>
