---
interface Props {
  email: string;
  phone: string;
  location: string;
  linkedin: string;
  github: string;
  t: typeof import('../data/translations.ts').translations.es;
}

const { email, phone, location, linkedin, github, t } = Astro.props;
---

<section id="contacto" class="py-32 relative">
  <div class="max-w-4xl mx-auto px-4">
    <div class="glass rounded-[2.5rem] overflow-hidden reveal">
      
      <!-- Terminal Header -->
      <div class="bg-white/10 dark:bg-white/5 border-b border-white/10 px-6 py-4 flex items-center justify-between">
        <div class="flex gap-2">
          <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
          <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
        </div>
        <div class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">contact.exe � {location}</div>
        <div class="w-12"></div>
      </div>

      <div class="p-6 md:p-12">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          
          <!-- Contact Info -->
          <div class="min-w-0">
            <h2 class="text-3xl md:text-4xl font-bold mb-8 font-heading">{t.contact.title}</h2>
            <div class="space-y-8">
              <div class="group reveal">
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Email</p>
                <a href={`mailto:${email}`} class="text-xs md:text-sm lg:text-base font-bold text-white hover:text-brand-cyan transition-colors flex items-center gap-3 whitespace-nowrap">
                  <i class="ti ti-mail text-brand-cyan shrink-0"></i>
                  {email}
                </a>
              </div>

              <div class="group reveal [transition-delay:100ms]">
                <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Phone</p>
                <a href={`tel:${phone}`} class="text-xl md:text-2xl font-bold text-white hover:text-brand-indigo transition-colors flex items-center gap-3">
                  <i class="ti ti-phone text-brand-indigo shrink-0"></i>
                  {phone}
                </a>
              </div>

              <div class="flex gap-4 pt-4 reveal [transition-delay:200ms]">
                <a href={linkedin} target="_blank" class="w-14 h-14 glass rounded-2xl flex items-center justify-center text-2xl hover:bg-brand-cyan hover:text-void transition-all duration-300">
                  <i class="ti ti-brand-linkedin"></i>
                </a>
                <a href={github} target="_blank" class="w-14 h-14 glass rounded-2xl flex items-center justify-center text-2xl hover:bg-white hover:text-void transition-all duration-300">
                  <i class="ti ti-brand-github"></i>
                </a>
              </div>
            </div>
          </div>

          <!-- Ticket Form -->
          <div class="glass p-6 md:p-8 rounded-3xl border-brand-cyan/20 w-full lg:max-w-md ml-auto">
            <h4 class="text-lg font-bold mb-6 font-heading flex items-center gap-2">
              <span class="w-2 h-2 bg-brand-cyan rounded-full animate-pulse"></span>
              {t.contact.ticketTitle}
            </h4>
            
            <form id="ticketForm"
              action="https://formspree.io/f/xojokgvj"
              method="POST"
              class="space-y-6"
              data-sending={t.contact.sending}
              data-success={t.contact.success}
              data-error={t.contact.error}
              data-submitbtn={t.contact.submitBtn}
              data-nameerror={t.contact.nameError}
              data-emailerror={t.contact.emailError}
              data-messageerror={t.contact.messageError}>
              <div class="relative">
                <input type="text" name="name" id="formName" placeholder=" " required
                  class="peer w-full bg-transparent border-b border-white/10 py-3 focus:outline-none focus:border-brand-cyan transition-colors text-white" />
                <label for="formName" class="absolute left-0 top-3 text-gray-500 transition-all peer-focus:-top-4 peer-focus:text-[10px] peer-focus:text-brand-cyan peer-focus:font-bold uppercase tracking-widest">{t.contact.nameLabel}</label>
                <p class="form-error text-red-400 text-xs mt-1 hidden" id="nameError"></p>
              </div>
              <div class="relative">
                <input type="email" name="email" id="formEmail" placeholder=" " required
                  class="peer w-full bg-transparent border-b border-white/10 py-3 focus:outline-none focus:border-brand-cyan transition-colors text-white" />
                <label for="formEmail" class="absolute left-0 top-3 text-gray-500 transition-all peer-focus:-top-4 peer-focus:text-[10px] peer-focus:text-brand-cyan peer-focus:font-bold uppercase tracking-widest">{t.contact.emailLabel}</label>
                <p class="form-error text-red-400 text-xs mt-1 hidden" id="emailError"></p>
              </div>
              <div class="relative">
                <textarea name="message" id="formMessage" placeholder=" " rows="3" required
                  class="peer w-full bg-transparent border-b border-white/10 py-3 focus:outline-none focus:border-brand-cyan transition-colors text-white resize-none"></textarea>
                <label for="formMessage" class="absolute left-0 top-3 text-gray-500 transition-all peer-focus:-top-4 peer-focus:text-[10px] peer-focus:text-brand-cyan peer-focus:font-bold uppercase tracking-widest">{t.contact.messageLabel}</label>
                <p class="form-error text-red-400 text-xs mt-1 hidden" id="messageError"></p>
              </div>
              
              <div id="formFeedback" class="text-sm text-center hidden"></div>
              
              <button type="submit" id="submitBtn" class="w-full bg-brand-cyan text-void font-bold py-4 rounded-xl hover:glow-cyan transition-all uppercase tracking-widest text-xs">
                {t.contact.submitBtn}
              </button>
            </form>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script>
  var EMAIL_REGEX$ = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function initForm$() {
    var form = document.getElementById('ticketForm');
    if (!form) return;

    var T = form.dataset;
    var submitBtn = document.getElementById('submitBtn');
    var nameInput = document.getElementById('formName');
    var emailInput = document.getElementById('formEmail');
    var messageInput = document.getElementById('formMessage');
    var nameError = document.getElementById('nameError');
    var emailError = document.getElementById('emailError');
    var messageError = document.getElementById('messageError');
    var feedback = document.getElementById('formFeedback');

    function hideErrors() {
      [nameError, emailError, messageError].forEach(function(el) { if (el) el.classList.add('hidden'); });
      [nameInput, emailInput, messageInput].forEach(function(el) {
        if (!el) return;
        el.classList.remove('border-red-400', 'border-brand-cyan');
        el.classList.add('border-white/10');
      });
      if (feedback) feedback.classList.add('hidden');
    }

    function showFieldError(input, errorEl, msg) {
      if (!input || !errorEl) return;
      input.classList.remove('border-white/10');
      input.classList.add('border-red-400');
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }

    function validate() {
      var valid = true;
      hideErrors();
      if (!nameInput || !emailInput || !messageInput) return false;

      var name = nameInput.value.trim();
      if (!name || name.length < 2) {
        showFieldError(nameInput, nameError, T.nameerror);
        valid = false;
      }

      var email = emailInput.value.trim();
      if (!email || !EMAIL_REGEX$.test(email)) {
        showFieldError(emailInput, emailError, T.emailerror);
        valid = false;
      }

      var message = messageInput.value.trim();
      if (!message || message.length < 10) {
        showFieldError(messageInput, messageError, T.messageerror);
        valid = false;
      }

      return valid;
    }

    function setLoading(loading) {
      var inputs = [nameInput, emailInput, messageInput];
      if (!submitBtn) return;
      if (loading) {
        submitBtn.disabled = true;
        submitBtn.textContent = T.sending;
        inputs.forEach(function(el) { if (el) el.readOnly = true; });
      } else {
        submitBtn.disabled = false;
        submitBtn.textContent = T.submitbtn;
        inputs.forEach(function(el) { if (el) el.readOnly = false; });
      }
    }

    function showFeedback(msg, type) {
      if (!feedback) return;
      feedback.textContent = msg;
      feedback.className = 'text-sm text-center p-3 rounded-xl ' + (
        type === 'success'
          ? 'text-green-400 bg-green-500/10 border border-green-500/20'
          : 'text-red-400 bg-red-500/10 border border-red-500/20'
      );
      feedback.classList.remove('hidden');
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      hideErrors();
      if (!validate()) return;
      setLoading(true);
      try {
        var res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { 'Accept': 'application/json' },
        });
        if (res.ok) {
          showFeedback(T.success, 'success');
          form.reset();
        } else {
          showFeedback(T.error, 'error');
        }
      } catch (_) {
        showFeedback(T.error, 'error');
      } finally {
        setLoading(false);
      }
    });
  }

  initForm$();
  document.addEventListener('astro:after-swap', initForm$);
</script>


