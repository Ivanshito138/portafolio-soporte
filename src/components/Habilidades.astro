---
interface Props {
  skills: { technical: Array<{ name: string; level: number }>; soft: string[] };
  t: typeof import('../data/translations.ts').translations.es;
}

const { skills, t } = Astro.props;
---

<section id="habilidades" class="py-20 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-6xl mx-auto px-4">
    <h2 class="text-3xl font-bold text-center mb-12 text-gray-900 dark:text-white font-heading">{t.skills.title}</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <h3 class="text-xl font-semibold mb-6 text-gray-800 dark:text-gray-200 font-heading">{t.skills.technical}</h3>
        <div class="space-y-4">
          {skills.technical.map((skill) => (
            <div>
              <div class="flex justify-between mb-1">
                <span class="font-medium text-gray-700 dark:text-gray-300">{skill.name}</span>
                <span class="text-gray-500 dark:text-gray-400">{skill.level}%</span>
              </div>
              <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2.5">
                <div
                  class="bg-blue-600 dark:bg-blue-500 h-2.5 rounded-full transition-all"
                  style={`width: ${skill.level}%`}
                  role="progressbar"
                  aria-valuenow={skill.level}
                  aria-valuemin={0}
                  aria-valuemax={100}
                  aria-label={`${skill.name}: ${skill.level}%`}
                ></div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h3 class="text-xl font-semibold mb-6 text-gray-800 dark:text-gray-200 font-heading">{t.skills.soft}</h3>
        <div class="flex flex-wrap gap-3">
          {skills.soft.map((skill) => (
            <span class="bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 px-4 py-2 rounded-full font-medium">
              {skill}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
