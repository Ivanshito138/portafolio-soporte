---
interface Props {
  name: string;
  t: typeof import('../data/translations.ts').translations.es;
}

const { name, t } = Astro.props;
---

<footer class="py-12 border-t border-white/5 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 relative z-10">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8 text-center md:text-left">
      <div>
        <h3 class="text-xl font-bold bg-gradient-to-r from-brand-cyan to-brand-indigo bg-clip-text text-transparent font-heading mb-2">
          {name}
        </h3>
        <p class="text-sm text-gray-500 max-w-xs leading-relaxed">
          {t.footer.role}. Resolviendo problemas complejos con soluciones simples.
        </p>
      </div>

      <div class="flex flex-col items-center md:items-end gap-2">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-gray-500 mb-2">Social Hub</p>
        <div class="flex gap-4">
          <a href="https://www.linkedin.com/in/ivan-raul-mesco-benavente/" target="_blank" class="text-gray-400 hover:text-brand-cyan transition-colors text-xl">
            <i class="ti ti-brand-linkedin"></i>
          </a>
          <a href="https://github.com/Ivanshito138" target="_blank" class="text-gray-400 hover:text-white transition-colors text-xl">
            <i class="ti ti-brand-github"></i>
          </a>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[10px] text-gray-600 uppercase tracking-widest">
        &copy; {new Date().getFullYear()} {name}. {t.footer.rights}
      </p>
      <div class="flex gap-6 text-[10px] text-gray-600 uppercase tracking-widest font-bold">
        <a href="#sobre-mi" class="hover:text-brand-cyan transition-colors">About</a>
        <a href="#proyectos" class="hover:text-brand-cyan transition-colors">Work</a>
        <a href="#contacto" class="hover:text-brand-cyan transition-colors">Contact</a>
      </div>
    </div>
  </div>
  
  <!-- Subtle decorative element -->
  <div class="absolute bottom-0 right-0 w-64 h-64 bg-brand-indigo/5 blur-[100px] rounded-full -z-10"></div>
</footer>
