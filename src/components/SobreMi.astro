---
interface Props {
  about: { paragraph1: string; paragraph2: string };
  t: typeof import('../data/translations.ts').translations.es;
}

const { about, t } = Astro.props;
---

<section id="sobre-mi" class="py-32 relative">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Content Section -->
      <div class="reveal">
        <h2 class="text-4xl md:text-5xl font-bold mb-8 font-heading">{t.about.title}</h2>
        <div class="space-y-6 text-lg text-gray-400 leading-relaxed">
          <p class="relative">
            <span class="absolute -left-8 top-0 text-brand-cyan/20 text-6xl font-serif">"</span>
            {about.paragraph1}
          </p>
          <p>{about.paragraph2}</p>
        </div>

        <div class="grid grid-cols-2 gap-4 mt-12">
          <div class="glass p-6 rounded-2xl group hover:glow-cyan transition-all duration-300">
            <p class="text-3xl font-bold text-brand-cyan font-heading group-hover:scale-110 transition-transform">3+</p>
            <p class="text-xs text-gray-500 uppercase tracking-widest font-bold mt-2">{t.about.yearsExperience}</p>
          </div>
          <div class="glass p-6 rounded-2xl group hover:glow-indigo transition-all duration-300">
            <p class="text-3xl font-bold text-brand-indigo font-heading group-hover:scale-110 transition-transform">500+</p>
            <p class="text-xs text-gray-500 uppercase tracking-widest font-bold mt-2">{t.about.ticketsResolved}</p>
          </div>
        </div>
      </div>

      <!-- Visual Side / Decorative Bento -->
      <div class="grid grid-cols-2 gap-4 reveal [transition-delay:200ms]">
        <div class="glass aspect-square rounded-3xl flex flex-col items-center justify-center p-6 group hover:glow-cyan transition-all duration-500">
          <i class="ti ti-heart-rate-monitor text-4xl text-brand-cyan mb-4"></i>
          <p class="text-2xl font-bold font-heading">95%</p>
          <p class="text-[10px] uppercase font-bold text-gray-500 tracking-widest mt-1">{t.about.satisfaction}</p>
        </div>
        
        <div class="glass aspect-square rounded-3xl overflow-hidden group">
          <img 
            src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?crop=entropy&cs=srgb&fm=jpg&q=85" 
            alt="Technical Dashboard" 
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700"
          />
        </div>

        <div class="glass col-span-2 p-8 rounded-3xl flex items-center gap-6 group hover:glow-indigo transition-all">
          <div class="w-16 h-16 glass rounded-2xl flex items-center justify-center text-brand-indigo group-hover:bg-brand-indigo/20">
            <i class="ti ti-device-laptop text-3xl"></i>
          </div>
          <div>
            <h4 class="font-bold font-heading text-lg">{t.about.specialist}</h4>
            <p class="text-sm text-gray-500">{t.about.focus}</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
